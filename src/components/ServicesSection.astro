---
import ServiceCard from './ServiceCard.astro';
import { services } from '../data/services';
---

<section id="services" class="py-16 md:py-24 bg-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-dark mb-4">What We Do</h2>
      <p class="text-gray-700 text-lg max-w-2xl mx-auto">
        From driveways to patios to stamped concrete, we deliver quality concrete work that lasts.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service) => (
        <ServiceCard
          icon={service.icon}
          title={service.title}
          description={service.description}
        />
      ))}
    </div>
  </div>
</section>
