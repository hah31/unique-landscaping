---
import { galleryItems } from '../data/gallery';

const previewItems = galleryItems.slice(0, 6);

const placeholderColors = [
  'from-primary/20 to-primary/5',
  'from-accent/20 to-accent/5',
  'from-primary-light/20 to-primary-light/5',
  'from-accent/15 to-primary/10',
  'from-primary/15 to-accent/10',
  'from-primary-light/15 to-accent/10',
];
---

<section id="gallery" class="py-16 md:py-24 bg-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-dark mb-4">Our Recent Work</h2>
      <p class="text-gray-700 text-lg max-w-2xl mx-auto">
        Take a look at some of the concrete projects we've completed for homeowners in the Bensenville area.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {previewItems.map((item, index) => (
        <div class="group relative rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow aspect-[4/3]">
          <div class={`w-full h-full bg-gradient-to-br ${placeholderColors[index]} flex flex-col items-center justify-center`}>
            <div class="text-5xl mb-3 opacity-60">
              {item.category === 'Driveways' ? '🚗' : item.category === 'Stamped Concrete' ? '✨' : item.category === 'Patios' ? '🏡' : item.category === 'Retaining Walls' ? '🧱' : '🚶'}
            </div>
            <p class="text-primary font-semibold text-sm">{item.category}</p>
            <p class="text-gray-400 text-xs mt-1">Photo coming soon</p>
          </div>
          <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/10 transition-colors" />
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-4 translate-y-full group-hover:translate-y-0 transition-transform">
            <p class="text-white text-sm font-medium">{item.alt}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="/gallery"
        class="inline-flex items-center text-primary font-semibold text-lg hover:text-primary-light transition-colors"
      >
        View All Projects
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</section>
