---
import { siteConfig } from '../data/siteConfig';
---

<footer class="bg-primary-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <!-- Business Info -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-10 h-10 bg-accent rounded-lg flex items-center justify-center">
            <span class="text-primary-dark font-extrabold text-xl">U</span>
          </div>
          <div>
            <span class="font-bold text-lg block leading-tight">Unique Concrete</span>
            <span class="text-gray-400 text-xs block leading-tight">Construction</span>
          </div>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          Family-owned concrete contractor serving Bensenville, IL and the western suburbs.
          Quality craftsmanship on every project.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-bold text-lg mb-4">Quick Links</h3>
        <nav class="space-y-2">
          <a href="/#services" class="block text-gray-400 hover:text-accent transition-colors">Services</a>
          <a href="/#about" class="block text-gray-400 hover:text-accent transition-colors">About Us</a>
          <a href="/gallery" class="block text-gray-400 hover:text-accent transition-colors">Gallery</a>
          <a href="/#contact" class="block text-gray-400 hover:text-accent transition-colors">Contact</a>
        </nav>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="font-bold text-lg mb-4">Contact Us</h3>
        <div class="space-y-3">
          <div>
            <p class="text-sm text-gray-400">{siteConfig.owners.david}</p>
            <a href={`tel:${siteConfig.phone.davidRaw}`} class="text-accent hover:text-accent-light font-semibold transition-colors">
              {siteConfig.phone.david}
            </a>
          </div>
          <div>
            <p class="text-sm text-gray-400">{siteConfig.owners.joel}</p>
            <a href={`tel:${siteConfig.phone.joelRaw}`} class="text-accent hover:text-accent-light font-semibold transition-colors">
              {siteConfig.phone.joel}
            </a>
          </div>
          <div class="pt-2">
            <a
              href={siteConfig.instagram.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-gray-400 hover:text-accent transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              {siteConfig.instagram.handle}
            </a>
          </div>
          <p class="text-sm text-gray-400">{siteConfig.location.full}</p>
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 mt-10 pt-8 text-center text-sm text-gray-400">
      <p>&copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
