---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6 md:p-8 text-center">
  <div class="text-4xl mb-4">{icon}</div>
  <h3 class="text-lg font-bold text-primary mb-2">{title}</h3>
  <p class="text-gray-700 text-sm leading-relaxed">{description}</p>
</div>
