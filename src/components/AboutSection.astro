---
import { siteConfig } from '../data/siteConfig';
---

<section id="about" class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
        <!-- Text -->
        <div>
          <h2 class="text-3xl md:text-4xl font-extrabold text-dark mb-6">
            Family-Owned.<br />Bensenville-Based.<br />Built on Trust.
          </h2>
          <div class="space-y-4 text-gray-700 leading-relaxed">
            <p>
              Unique Concrete Construction is a family business run by David and Joel
              De La Cruz right here in Bensenville, Illinois. We don't just pour
              concrete &mdash; we take pride in every driveway, every patio, and every
              walkway we build.
            </p>
            <p>
              Our customers are our neighbors, and our reputation is built one project
              at a time. When you work with us, you work directly with the owners. No
              middlemen, no runaround &mdash; just honest work and quality results.
            </p>
          </div>
          <div class="mt-8">
            <a
              href="#contact"
              class="inline-flex items-center text-primary font-semibold hover:text-primary-light transition-colors"
            >
              Get in touch
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>

        <!-- Visual placeholder -->
        <div class="bg-gray-100 rounded-2xl p-8 flex flex-col items-center justify-center min-h-[300px]">
          <div class="w-24 h-24 bg-primary rounded-full flex items-center justify-center mb-6">
            <span class="text-accent font-extrabold text-3xl">U</span>
          </div>
          <p class="text-primary font-bold text-xl text-center">{siteConfig.name}</p>
          <p class="text-gray-700 text-sm mt-2">Serving {siteConfig.location.full} since day one</p>
          <div class="flex gap-4 mt-6 text-sm text-gray-700">
            <span class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Family-Owned
            </span>
            <span class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Licensed
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
