---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/siteConfig';
import { url } from '../data/utils';
---

<BaseLayout title={`Page Not Found | ${siteConfig.name}`}>
  <section class="py-24 md:py-36 bg-gray-100">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <div class="text-6xl mb-6 opacity-40">🏗️</div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-dark mb-4">Page Not Found</h1>
      <p class="text-gray-700 text-lg mb-8">
        This page doesn't exist &mdash; but great concrete does.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={url('/')}
          class="inline-flex items-center justify-center bg-primary hover:bg-primary-light text-white font-bold px-8 py-4 rounded-lg transition-colors"
        >
          Back to Home
        </a>
        <a
          href={`tel:${siteConfig.phone.davidRaw}`}
          class="inline-flex items-center justify-center border-2 border-primary text-primary hover:bg-primary hover:text-white font-bold px-8 py-4 rounded-lg transition-colors"
        >
          Call {siteConfig.phone.david}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
